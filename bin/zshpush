#!/usr/bin/env zsh
# Commit dirty zsh config changes with aiCommit, then push the current branch.

if (( $# != 0 )); then
  echo "usage: zshpush" >&2
  exit 2
fi

config_dir="${ZSHRC_CONFIG_DIR:-$HOME/.zshrc_config}"

if [[ ! -d "$config_dir" ]]; then
  echo "zshpush: config directory not found: $config_dir" >&2
  exit 1
fi

if ! git -C "$config_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "zshpush: $config_dir is not a git repository" >&2
  exit 1
fi

branch="$(git -C "$config_dir" branch --show-current)"
if [[ -z "$branch" ]]; then
  echo "zshpush: $config_dir is not on a branch" >&2
  exit 1
fi

ai_commit_cmd="$config_dir/bin/aiCommit"
if [[ ! -x "$ai_commit_cmd" ]]; then
  ai_commit_cmd="$(command -v aiCommit 2>/dev/null)"
fi

if [[ -z "$ai_commit_cmd" ]]; then
  echo "zshpush: aiCommit is not available" >&2
  exit 1
fi

if [[ -n "$(git -C "$config_dir" status --porcelain)" ]]; then
  echo "zshpush: committing dirty files in $config_dir"
  (cd "$config_dir" && "$ai_commit_cmd") || exit
else
  echo "zshpush: no dirty files in $config_dir"
fi

upstream="$(git -C "$config_dir" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
if [[ -n "$upstream" ]]; then
  echo "zshpush: pushing $branch to $upstream"
  git -C "$config_dir" push
else
  echo "zshpush: pushing $branch and setting upstream to origin/$branch"
  git -C "$config_dir" push --set-upstream origin "$branch"
fi
