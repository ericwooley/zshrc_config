#!/usr/bin/env zsh
# Create a concise AI-assisted git commit.
# Stages all changes, asks fastAI for an imperative subject under 50 chars,
# strips risky shell quoting, and commits with that message.

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "aiCommit: not inside a git repository" >&2
  exit 1
fi

git add --all || exit

if git diff --cached --quiet --exit-code --no-ext-diff; then
  echo "aiCommit: nothing to commit" >&2
  exit 1
fi

prompt_file="$(mktemp "${TMPDIR:-/tmp}/aiCommit-prompt.XXXXXX")" || exit
editor_file="$(mktemp "${TMPDIR:-/tmp}/aiCommit-editor.XXXXXX")" || {
  rm -f "$prompt_file"
  exit 1
}

cleanup() {
  rm -f "$prompt_file" "$editor_file"
}
trap cleanup EXIT INT TERM

{
  print -r -- "Write a concise git commit subject for this staged diff."
  print -r -- ""
  print -r -- "Rules:"
  print -r -- "- Output only the commit message."
  print -r -- "- Use imperative mood."
  print -r -- "- Keep it under 50 characters."
  print -r -- "- No quotes, markdown, bullets, explanations, or trailing period."
  print -r -- ""
  print -r -- "Diff:"
  git diff --cached --no-ext-diff --no-color
} >| "$prompt_file" || exit

cat >| "$editor_file" <<'EOF' || exit
#!/bin/sh
if [ "$#" -lt 1 ]; then
  echo "aiCommit editor shim: prompt path is required" >&2
  exit 2
fi

cat "$FASTAI_PROMPT_FILE" > "$1"
EOF
chmod +x "$editor_file" || exit

message="$(
  FASTAI_PROMPT_FILE="$prompt_file" \
  VISUAL="$editor_file" \
  EDITOR="$editor_file" \
    fastAI \
    --provider "${FASTAI_DEFAULT_PROVIDER:-openrouter}" \
    --model "${FASTAI_DEFAULT_MODEL:-deepseek/deepseek-v4-flash}" \
    --permissions none \
    --no-session
)" || exit

message="${message%%$'\n'*}"
message="${message//$'\r'/}"
message="${message//\"/}"
message="${message//\`/}"
message="${message#"${message%%[![:space:]]*}"}"
message="${message%"${message##*[![:space:]]}"}"

if [[ -z "$message" ]]; then
  echo "aiCommit: fastAI returned an empty commit message" >&2
  exit 1
fi

if (( ${#message} > 50 )); then
  message="${message[1,50]}"
fi

echo "aiCommit: $message"
git commit -am "$message"
