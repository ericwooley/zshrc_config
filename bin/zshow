#!/usr/bin/env zsh
# Ask fastAI how to use this zsh setup, then render the Markdown answer.

set -euo pipefail

question_file=""
question_from_editor=0
new_session=0

usage() {
  echo "usage: zshow [--new] [question words...]" >&2
}

cleanup() {
  if [[ -n "${question_file:-}" && -f "$question_file" ]]; then
    rm -f "$question_file"
  fi
}

print_editor_question() {
  if [[ -t 2 ]]; then
    printf '\n\033[1;36mzshow\033[0m \033[1mquestion\033[0m\n' >&2
    printf '\033[2m----------------\033[0m\n' >&2
  else
    printf '\nzshow question\n----------------\n' >&2
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    printf '  %s\n' "$line" >&2
  done <<< "$question"

  printf '\n' >&2
}

strip_editor_comments() {
  awk '
    {
      line = $0
      sub(/^[[:space:]]+/, "", line)
      if (substr(line, 1, 1) == "#") {
        next
      }
      print
    }
  ' "$1"
}

zshow_history_comments() {
  if ! command -v node >/dev/null 2>&1 || ! command -v git >/dev/null 2>&1; then
    return 0
  fi

  local repo_root
  repo_root="$(git -C "$config_dir" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -z "$repo_root" ]]; then
    return 0
  fi

  node - "$repo_root" <<'NODE'
const crypto = require("crypto");
const fs = require("fs");
const os = require("os");
const path = require("path");

const repoRoot = process.argv[2];

function userConfigDir() {
  if (process.env.XDG_CONFIG_HOME) {
    return process.env.XDG_CONFIG_HOME;
  }
  if (process.platform === "darwin") {
    return path.join(os.homedir(), "Library", "Application Support");
  }
  if (process.platform === "win32") {
    return process.env.APPDATA || path.join(os.homedir(), "AppData", "Roaming");
  }
  return path.join(os.homedir(), ".config");
}

function repoKey(repo) {
  let clean = path.resolve(repo);
  if (process.platform === "win32") {
    clean = clean.slice(0, 1).toLowerCase() + clean.slice(1);
  }
  return crypto.createHash("sha256").update(clean).digest("hex").slice(0, 32);
}

function oneLine(value) {
  return String(value || "").replace(/\s+/g, " ").trim();
}

function extractQuestion(prompt) {
  const patterns = [
    /User input to answer as a how-do-I question:\n([\s\S]*?)\n\n~\/\.zshrc_config context:/,
    /User input:\n([\s\S]*?)\n\n~\/\.zshrc_config context:/,
    /Question:\s*\n?([\s\S]*?)\n\n?~\/\.zshrc_config context:/,
  ];
  for (const pattern of patterns) {
    const match = String(prompt || "").match(pattern);
    if (match && oneLine(match[1])) {
      return oneLine(match[1]);
    }
  }
  return oneLine(prompt);
}

function printWrapped(label, value) {
  const text = oneLine(value) || "(empty)";
  const width = 84;
  let rest = `${label}: ${text}`.slice(0, 700);
  while (rest.length > width) {
    let splitAt = rest.lastIndexOf(" ", width);
    if (splitAt < 20) {
      splitAt = width;
    }
    console.log(`# ${rest.slice(0, splitAt)}`);
    rest = `  ${rest.slice(splitAt).trimStart()}`;
  }
  console.log(`# ${rest}`);
}

const historyPath = path.join(userConfigDir(), "fastAI", "sessions", repoKey(repoRoot), "global.json");
if (!fs.existsSync(historyPath)) {
  process.exit(0);
}

const record = JSON.parse(fs.readFileSync(historyPath, "utf8"));
const runs = Array.isArray(record.runs) ? record.runs.slice(-5) : [];
if (runs.length === 0) {
  process.exit(0);
}

console.log(`# Recent zshow history: last ${runs.length} question/answer pair${runs.length === 1 ? "" : "s"}`);
console.log("# Lines starting with # are ignored when zshow reads your question.");
runs.forEach((run, index) => {
  console.log("#");
  printWrapped(`Q${index + 1}`, extractQuestion(run.prompt));
  printWrapped(`A${index + 1}`, run.summary);
});
NODE
}

write_editor_template() {
  {
    print -r -- "# zshow question"
    print -r -- "# Type your question below. Lines starting with # are ignored."
    print -r -- "#"
    if (( new_session )); then
      print -r -- "# --new is set, so the previous zshow session will be reset."
    else
      zshow_history_comments || true
    fi
    print -r -- ""
  } > "$question_file"
}

trap cleanup EXIT

question_parts=()
while (( $# > 0 )); do
  case "$1" in
    --new)
      new_session=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      question_parts+=("$@")
      break
      ;;
    *)
      question_parts+=("$1")
      shift
      ;;
  esac
done

if ! command -v fastAI >/dev/null 2>&1; then
  echo "zshow: fastAI is not installed or not on PATH" >&2
  exit 1
fi

if ! command -v glow >/dev/null 2>&1; then
  echo "zshow: glow is not installed or not on PATH" >&2
  exit 1
fi

config_dir="${ZSHRC_CONFIG_DIR:-$HOME/.zshrc_config}"

if [[ ! -d "$config_dir" ]]; then
  echo "zshow: config directory not found: $config_dir" >&2
  exit 1
fi

if (( ${#question_parts[@]} > 0 )); then
  question="${question_parts[*]}"
else
  editor="${EDITOR:-vi}"
  editor_cmd=("${(z)editor}")

  if (( ${#editor_cmd[@]} == 0 )) || ! command -v "$editor_cmd[1]" >/dev/null 2>&1; then
    echo "zshow: EDITOR is not usable: $editor" >&2
    exit 1
  fi

  question_file="$(mktemp -t zshow.XXXXXX)"
  write_editor_template
  "$editor_cmd[@]" "$question_file"
  question="$(strip_editor_comments "$question_file")"
  question_from_editor=1
fi

question="${question//$'\r'/}"
question="${question#"${question%%[![:space:]]*}"}"
question="${question%"${question##*[![:space:]]}"}"

if [[ -z "$question" ]]; then
  echo "zshow: no question provided" >&2
  exit 2
fi

if (( question_from_editor )); then
  print_editor_question
fi

context="$(
  find "$config_dir" -type f \
    ! -path '*/.git/*' \
    ! -path '*/generated-completions/*' \
    ! -name '*.zwc' \
    ! -name '*.log' \
    | sort \
    | while IFS= read -r file; do
        case "$file" in
          *.zsh|*.sh|*.md|*.txt|*.conf|*/bin/*)
            rel="${file#$config_dir/}"
            printf '\n--- %s ---\n' "$rel"
            sed -n '1,240p' "$file"
            ;;
        esac
      done
)"

prompt=$'You answer questions about this personal zsh setup.\n\nThe user input is meant to be a question, even when it is a bare fragment without punctuation because shell quoting is annoying. Interpret inputs like "create a file in nvim" or "do something useful" as "How do I create a file in nvim?" or "How do I do something useful with this setup?"\n\nUse fastAI session memory for follow-up context, and use the provided ~/.zshrc_config context for current facts. If the answer is not present in the session memory or local zsh config context, say that it is not documented locally.\n\nRules:\n- Output Markdown.\n- Be concise and practical.\n- Prefer exact commands, file paths, and key names when available.\n- Do not invent behavior that is not supported by the context.\n\nUser input to answer as a how-do-I question:\n'"$question"$'\n\n~/.zshrc_config context:\n'"$context"

if (( new_session )); then
  fastai_session_args=(--newGlobalSession)
else
  fastai_session_args=(--globalSession)
fi

(
  cd "$config_dir"
  fastAI \
    --provider "${FASTAI_DEFAULT_PROVIDER:-openrouter}" \
    --model "${FASTAI_DEFAULT_MODEL:-deepseek/deepseek-v4-flash}" \
    --permissions none \
    "${fastai_session_args[@]}" \
    "$prompt"
) | glow -
